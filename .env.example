# Copy this file to `.env` and replace the placeholder value with your real key.

MARKET_DATA_SOURCE=binancePublicData
COINMARKETCAP_API_KEY=replace_with_your_coinmarketcap_api_key
COINMARKETCAP_USE_CONTEXT=false
COINMARKETCAP_USE_MARKET_INTELLIGENCE=false
COINMARKETCAP_REFRESH_CONTEXT_AFTER_MARKET_REFRESH=false
COINMARKETCAP_REFRESH_MARKET_INTELLIGENCE_AFTER_MARKET_REFRESH=false
COINMARKETCAP_REQUEST_PAUSE_SECONDS=0.5
COINMARKETCAL_USE_EVENTS=false
KRAKEN_PRODUCT_IDS=BTC-USD,ETH-USD,SOL-USD
KRAKEN_GRANULARITY_SECONDS=3600
KRAKEN_TOTAL_CANDLES=720
KRAKEN_PRODUCT_BATCH_SIZE=25
BINANCE_PRODUCT_IDS=BTC-USD,ETH-USD,SOL-USD
BINANCE_FETCH_ALL_QUOTE_PRODUCTS=true
BINANCE_QUOTE_CURRENCY=USDT
BINANCE_MAX_PRODUCTS=150
BINANCE_INTERVAL=1h
BINANCE_GRANULARITY_SECONDS=3600
BINANCE_TOTAL_CANDLES=4320
BINANCE_ARCHIVE_LOOKBACK_MONTHS=36
BINANCE_PRODUCT_BATCH_SIZE=25
CONTINUOUS_MARKET_DATA_SOURCE=kraken
CONTINUOUS_LEARNING_INTERVAL_SECONDS=3600
CONTINUOUS_LEARNING_ERROR_SLEEP_SECONDS=300
CONTINUOUS_LEARNING_EVALUATION_INTERVAL_CYCLES=6
CONTINUOUS_LEARNING_RUN_BACKTEST=true
CONTINUOUS_LEARNING_MAX_CYCLES=0
LIVE_FETCH_ALL_QUOTE_PRODUCTS=true
LIVE_MAX_PRODUCTS=100
LIVE_PRODUCT_IDS=BTC-USD,ETH-USD,SOL-USD
MARKET_PRODUCT_BATCH_ROTATION_ENABLED=true
BACKTEST_MIN_CONFIDENCE=0.65
SIGNAL_MODEL_FAMILY=baseline_current
SIGNAL_MODEL_VARIANT=default
ENABLE_TFT_EXPERIMENTS=false
COMPARISON_RUN_WALK_FORWARD=false
SIGNAL_WATCHLIST_FALLBACK_ENABLED=true
SIGNAL_WATCHLIST_FALLBACK_HOURS=12
SIGNAL_WATCHLIST_MIN_DECISION_SCORE=0.30
SIGNAL_WATCHLIST_MIN_CONFIDENCE=0.55
SIGNAL_WATCHLIST_POOL_ENABLED=true
SIGNAL_WATCHLIST_POOL_MAX_PRODUCTS=12
LIVE_WATCHLIST_POOL_CACHE_SECONDS=15
SIGNAL_TRACK_GENERATED_TRADES=true
SIGNAL_GENERATED_TRADE_STATUS=planned
AI_ENGINE_INTERNAL_API_KEY=replace_with_the_same_shared_backend_model_secret
EVENT_WINDOW_MINUTES=360
EVENT_POST_WINDOW_MINUTES=240
EVENT_HIGH_IMPACT_THRESHOLD=0.65
NEWS_POSITIVE_SENTIMENT_THRESHOLD=0.20
NEWS_NEGATIVE_SENTIMENT_THRESHOLD=-0.20
CHART_FEATURE_WINDOW=60
CHART_BREAKOUT_BUFFER_PCT=0.005
CHART_RETEST_TOLERANCE_PCT=0.003
CHART_NEAR_RESISTANCE_PCT=0.01
CHART_POSITIVE_DECISION_BOOST=0.05
CHART_NEGATIVE_DECISION_PENALTY=0.08
CHART_SNAPSHOT_ENABLED=false
CHART_SNAPSHOT_MAX_SIGNALS=6
CHART_EVAL_MAX_ROWS_TOTAL=50000
